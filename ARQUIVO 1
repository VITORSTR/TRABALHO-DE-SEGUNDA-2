package br.com.cdl.moviehub.modelos;

public class Anime extends Titulo {
    private String estúdio;
    private int numEpisódios;

    public String getEstúdio() {
        return estúdio;
    }

    public void setEstúdio(String estúdio) {
        this.estúdio = estúdio;
    }

    public int getNumEpisódios() {
        return numEpisódios;
    }

    public void setNumEpisódios(int numEpisódios) {
        this.numEpisódios = numEpisódios;
    }

    @Override
    public int getDuracaoEmMinutos() {
        return getTotalEmMinutos();
    }

    @Override
    public void exibeFichaTecnica() {
        super.exibeFichaTecnica();
        System.out.println("Estúdio: " + this.estúdio);
        System.out.println("Número de Episódios: " + this.numEpisódios);
        System.out.println("===========================================");
    }
}
